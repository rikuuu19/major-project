<% layout("layouts/boilerplate") %>
<div class="row mt-3">
    <div class="col-6 offset-3">
        <br><br>
         <h3>Sign Up on Wandero</h3><br>
         <form action="/signup" method="post" novalidate class="needs-validation">
        <div class="mb-3">
            <label for="email" class="form-label">Enter Email</label>
            <input type="email" name="email" 
            placeholder="Enter your email" class="form-control" required/>
            <div class="valid-feedback">Email looks good</div>
        </div>

        <div class="mb-3">
            <label for="username" class="form-label">Enter Username</label>
            <input type="text" name="username"
            id="username" placeholder="Enter your username" class="form-control" required/>
            <div class="valid-feedback">Looks good!</div>
        </div>

        <div class="mb-3">
            <label for="password" class="form-label">Enter Password</label>
            <input type="password" name="password" 
            placeholder="Enter your password" class="form-control" required/>
            <div class="invalid-feedback">Please enter a password.</div>
        </div>

        <button class="btn btn-success add-btn">Sign Up</button>
        <br><br>
        </div>
        </div>
    </form>