<% layout("layouts/boilerplate") %>

<div class="row mt-3">
    <div class="col-8 offset-3">
        <h3><%= listing.title %></h3>
    </div>

    <div class="card col-6 offset-3 show-card listing-card">
        <!-- Safe Image -->
        <img src="<%= listing.image?.url || '/default.jpg' %>" 
             class="card-img-top show-img" alt="listing_image">

        <div class="card-body">
            <p class="card-text">
                <!-- Owned by <i><%= listing.Owner.username %></i> -->
                 Owned by <i><%= listing.Owner ? listing.Owner.username : "Unknown" %></i>
                 
            </p>

            <p class="card-text"><%= listing.description %></p>

            <p class="card-text">
                &#8377; <%= listing.price.toLocaleString("en-IN") %> / night
            </p>

            <p class="card-text"><%= listing.location %></p>
            <p class="card-text"><%= listing.country %></p>
        </div>
    </div>

    <div class="mt-4"></div>

    <!-- Edit/Delete Listing -->
    <!-- <% if(currUser && currUser._id.equals(listing.Owner._id)) { %> -->
        <% if(currUser && listing.Owner && currUser._id.equals(listing.Owner._id)) { %>
        <div class="btns">
            <a href="/listings/<%= listing._id %>/edit" 
               class="btn btn-dark col-1 offset-3 edit-btn">Edit</a>

            <div class="mt-2"></div>

            <form action="/listings/<%= listing._id %>?_method=DELETE" method="post">
                <button class="btn btn-dark offset-5" type="submit">Delete</button>
            </form>
        </div>
    <% } %>

    <div class="col-8 offset-3 mb-3">
        <hr>

        <!-- Review Form -->
        <% if(currUser) { %>
            <h4>Leave A Review</h4>

            <form action="/listings/<%= listing._id %>/reviews" 
                  method="POST" novalidate class="needs-validation">

                <div class="mb-3 mt-3">
                    <label class="form-label">Rating</label>

                    <fieldset class="starability-slot">
                        <!-- <input type="radio" id="no-rate" class="input-no-rate"
                               name="review[rating]" value="" checked /> -->
                        <input type="radio" id="first-rate5" 
                        name="review[rating]" value="5" checked />

                        <input type="radio" id="first-rate1" name="review[rating]" value="1" />
                        <label for="first-rate1">1 star</label>

                        <input type="radio" id="first-rate2" name="review[rating]" value="2" />
                        <label for="first-rate2">2 stars</label>

                        <input type="radio" id="first-rate3" name="review[rating]" value="3" />
                        <label for="first-rate3">3 stars</label>

                        <input type="radio" id="first-rate4" name="review[rating]" value="4" />
                        <label for="first-rate4">4 stars</label>

                        <input type="radio" id="first-rate5" name="review[rating]" value="5" />
                        <label for="first-rate5">5 stars</label>
                    </fieldset>
                </div>

                <div class="mb-3 mt-3">
                    <label for="comment" class="form-label">Comment</label>

                    <textarea id="comment" name="review[comment]" 
                              cols="30" rows="5" required></textarea>

                    <div class="invalid-feedback">
                        Please add some comment for the review
                    </div>
                </div>

                <button type="submit" class="btn btn-outline-dark">
                    Submit Review
                </button>
            </form>

            <hr>
        <% } %>

        <!-- Reviews Section -->
        <p><b>All Reviews</b></p>

        <% if(listing.reviews.length === 0) { %>
            <p>No reviews yet.</p>
        <% } %>

        <div class="row">
            <% for(let review of listing.reviews) { %>
                <div class="card col-5 ms-3 mb-3">
                    <div class="card-body">
                        <h5 class="card-title">
                            <!-- <%= review.author.username %> -->
                             <%= review.author ? review.author.username : "Anonymous" %>
                        </h5>

                        <p class="starability-result card-text" 
                           data-rating="<%= review.rating %>"></p>

                        <p class="card-text"><%= review.comment %></p>

                        <!-- Only author can delete review -->
                        <% if(currUser && currUser._id.equals(review.author._id)) { %>
                            <form class="mb-3"
                                  action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=DELETE"
                                  method="post">
                                <button class="btn btn-dark btn-sm">Delete</button>
                            </form>
                        <% } %>
                    </div>
                </div>
            <% } %>
        </div>

        <hr>

        <h4>Where you'll be</h4>
<div id="map" style="height:400px; margin-top:20px;"></div>


<script>
window.onload = () => {
    // const listingData = JSON.parse('<%- JSON.stringify(listing) %>');
    const listingData = <%- JSON.stringify(listing) %>;

    if (listingData.geometry && listingData.geometry.coordinates.length > 0) {

        const coords = listingData.geometry.coordinates;

        const map = new maplibregl.Map({
            container: 'map',
            style: 'https://tiles.openfreemap.org/styles/bright',
            center: coords,
            zoom: 10
        });

        new maplibregl.Marker()
            .setLngLat(coords)
            .addTo(map);

    } else {
        document.getElementById("map").innerHTML = "No location available";
    }
};
</script>

    </div>
</div>